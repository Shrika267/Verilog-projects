module parity (in1, out1, out2); 
        input [2:0]in1;
		  output reg out1, out2; 
        reg temp; 
        always@(*) 
        begin 
            temp <= in1[0]^in1[1]^in1[2]; 
            if(temp) 
            begin 
                out1<= 1'b1; 
                out2  <= 1'b0; 
            end 
            else 
            begin 
                out1 <= 1'b0; 
                out2   <= 1'b1; 
            end 
        end 
        endmodule
